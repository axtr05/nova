# Gemini API
# Required for the AI Action Engine (NOVA to translate NLP to JSON actions)
GEMINI_API_KEY="your_gemini_api_key_here"

# Firebase Authentication Config
# Required to enable user sign-in and protected routes
NEXT_PUBLIC_FIREBASE_API_KEY="your_api_key_here"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your_auth_domain_here"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your_project_id_here"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="your_storage_bucket_here"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="your_messaging_sender_id_here"
NEXT_PUBLIC_FIREBASE_APP_ID="your_app_id_here"

# Google Calendar API Configuration
# To enable Google Calendar Sync:
# 1. Go to Google Cloud Console (https://console.cloud.google.com)
# 2. Select or create a project
# 3. Go to "APIs & Services" > "Library" and enable "Google Calendar API"
# 4. Go to "OAuth consent screen" and add the scope: https://www.googleapis.com/auth/calendar.events
# 5. (Firebase handles the OAuth client ID automatically if you enabled Google Sign-In)
